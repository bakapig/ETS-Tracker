# Copy to backend/.env for local dev. Never commit real values.
#
# Malaysia Open API (optional — request higher rate limit from dataterbuka@jdn.gov.my)
# DATA_GOV_MY_API_TOKEN=

# Client API key — if set, mobile/web must send header X-API-Key (leave empty for open dev)
# API_KEY=

# Protects POST /api/admin/refresh-static (header X-Admin-Key)
# ADMIN_API_KEY=

# Comma-separated web origins (add your Vercel URL in production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

USER_AGENT=KTMB-Live-Malaysia/1.0 (contact: you@example.com)
